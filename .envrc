# Share a single .venv across the main checkout and all .worktrees/* clones.
# `git rev-parse --git-common-dir` points at the main repo's .git directory
# regardless of which worktree we're in, so the venv path resolves to the
# main checkout root for every sibling worktree.
export UV_PROJECT_ENVIRONMENT="$(dirname "$(git rev-parse --path-format=absolute --git-common-dir)")/.venv"
