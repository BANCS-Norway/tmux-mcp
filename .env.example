# Public HTTPS URL the MCP server is reachable at (no trailing slash).
# Typically the Tailscale Serve hostname, e.g. https://<machine>.<tailnet>.ts.net
TMUX_MCP_PUBLIC_URL=https://example.ts.net

# GitHub OAuth App credentials. Create at:
# https://github.com/settings/developers → New OAuth App
#   Homepage URL:          https://example.ts.net
#   Authorization callback: https://example.ts.net/oauth/github/callback
TMUX_MCP_GITHUB_CLIENT_ID=
TMUX_MCP_GITHUB_CLIENT_SECRET=

# Comma-separated GitHub usernames allowed to authenticate.
# Anyone else signing in via GitHub will be rejected at the callback.
TMUX_MCP_ALLOWED_GITHUB_USERS=your-github-handle

# Bind host. Use 127.0.0.1 when fronting with `tailscale serve` (recommended).
# TMUX_MCP_HOST=127.0.0.1

# Listen port (backend HTTP).
# TMUX_MCP_PORT=8747

# Default tmux session target for tools.
# TMUX_MCP_SESSION=0
